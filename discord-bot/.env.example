# ── Discord ──────────────────────────────────────────────────────────────────
# Bot token from the Discord Developer Portal → your app → Bot tab
DISCORD_TOKEN=your_discord_bot_token_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — Developer Portal → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — Developer Portal → Settings → API → service_role
# Keep this secret. It bypasses Row Level Security.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Discord Guild (server) ID for instant slash-command registration during development.
# Guild-scoped commands appear immediately; global commands can take up to 1 hour.
# Remove this line (or leave blank) for global registration in production.
GUILD_ID=
