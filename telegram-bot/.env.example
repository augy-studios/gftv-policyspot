# ── Telegram credentials ──────────────────────────────────────────────────────
# Obtain api_id and api_hash from https://my.telegram.org → API development tools
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (NOT the anon key) from Supabase dashboard → Settings → API
# Keep this secret — it bypasses Row Level Security
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# How long (in seconds) to cache Supabase responses locally. Default: 300 (5 min)
# CACHE_TTL=300
